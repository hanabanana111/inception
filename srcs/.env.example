# Public domain used to access the platform through HTTPS.
DOMAIN_NAME=your_login.42.fr

# MariaDB database name used by WordPress.
SQL_DATABASE=wordpress

# MariaDB application user used by WordPress.
SQL_USER=wpuser

# File-based secret path for the MariaDB application user password.
SQL_PASSWORD_FILE=/run/secrets/db_password

# File-based secret path for the MariaDB root password.
SQL_ROOT_PASSWORD_FILE=/run/secrets/db_root_password

# WordPress administrator username (security note: avoid using 'admin').
WP_ADMIN_USER=

# File-based secret path for the WordPress administrator password.
WP_ADMIN_PASSWORD_FILE=/run/secrets/credentials

# WordPress regular user username.
WP_USER=

# File-based secret path for the WordPress regular user password.
WP_USER_PASSWORD_FILE=/run/secrets/credentials
